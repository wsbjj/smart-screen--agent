{
  "name": "smart-screen--agent",
  "private": true,
  "version": "0.3.1",
  "description": "Desktop resume screening agent",
  "author": "wsbjj",
  "type": "module",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && npm run electron:dev\"",
    "postinstall": "npm run rebuild:native:electron",
    "pretest": "npm run rebuild:native:node",
    "preelectron:dev": "npm run rebuild:native:electron",
    "prestart": "npm run rebuild:native:electron",
    "prepackage": "npm run rebuild:native:electron",
    "prepackage:win": "npm run rebuild:native:electron",
    "prepackage:mac:arm64": "npm run rebuild:native:electron",
    "rebuild:native:node": "npm rebuild better-sqlite3 keytar",
    "rebuild:native:electron": "electron-builder install-app-deps && electron-rebuild -f -w better-sqlite3 -w keytar",
    "electron:dev": "npm run build:electron && node scripts/electron-dev.mjs",
    "build": "tsc -b && vite build && npm run build:electron",
    "check:platform": "node scripts/check-cross-platform.mjs",
    "check:release-version": "node scripts/check-release-version.mjs",
    "build:electron": "tsc -p tsconfig.electron.json",
    "lint": "eslint .",
    "package": "npm run build && electron-builder --publish never",
    "package:win": "npm run build && electron-builder --win nsis --x64 --publish never",
    "package:mac:arm64": "npm run build && electron-builder --mac dmg --arm64 --publish never",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "start": "electron ."
  },
  "dependencies": {
    "@openai/agents": "^0.11.6",
    "better-sqlite3": "^12.11.1",
    "dotenv": "^17.4.2",
    "electron-store": "^11.0.2",
    "exceljs": "^4.4.0",
    "keytar": "^7.9.0",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.13.2",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.3",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "tsx": "^4.22.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.9",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.wsbjj.smartscreenagent",
    "productName": "简历筛选助手",
    "artifactName": "jianli-shaixuan-zhushou-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/*.node",
      "node_modules/better-sqlite3/**"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
